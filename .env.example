# Django Configuration
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True

# SMTP Email Configuration
# Set these parameters to enable actual Gmail SMTP sending.
# If these are left blank, MailPulse will fall back to using
# Django's console email backend for development convenience.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# Google OAuth (Sign in with Google)
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials (Web Application type)
# 3. Add authorized redirect URI: http://localhost:8000/accounts/google/login/callback/
# 4. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
